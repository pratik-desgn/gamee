# ─── GAMEE Backend Configuration ───
# Copy this to .env and fill in your values.
#
# cp .env.example .env
# docker compose --env-file .env up -d

# ─── Server ───
PORT=8080
ENVIRONMENT=development
READ_TIMEOUT=30s
WRITE_TIMEOUT=30s

# ─── Database ───
DATABASE_URL=postgres://gamee:***@localhost:5432/gamee?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_DB=0

# ─── Auth ───
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRATION=24h

# ─── Solana ───
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WSS_URL=wss://api.devnet.solana.com/
SOLANA_COMMITMENT=confirmed
PROGRAM_ID=                 # Set after anchor build (from gamee-keypair.json)
VAULT_ADDRESS=              # Set after deploy
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
VERIFIER_KEY_PATH=./keys/verifier.json

# ─── Game Engine ───
TICK_RATE=60
MAX_PLAYERS=10000
REPLAY_WORKERS=4

# ─── Rate Limiting ───
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=20

# ─── Admin / Payout Review (Stage 3) ───
ADMIN_API_KEY=                       # Required to use /api/v1/admin/*; unset = admin routes refuse all requests
LARGE_PAYOUT_REVIEW_THRESHOLD=1000000000   # 1,000 USDC (base units); payouts >= this are held for staff approval
AUTO_REVIEW_MAX_PAYOUT=10000000000  # 10,000 USDC (base units); held payouts with clean trust signals auto-approve below this. <=0 disables auto-review (fully manual)

# ─── Docker-Only ───
DB_PASSWORD=gamee_dev_pass
